# PostgreSQL Chaos Experiments - Environment Variables
# =====================================================
# Copy this file to .env and modify values as needed:
#   cp env.example .env
#   source .env
#
# Or source directly with defaults:
#   source env.example

# =============================================================================
# OpenTelemetry Configuration
# =============================================================================

# OTLP endpoint for traces, metrics, and logs
# NOTE: For chaosotel traces we use gRPC on port 4317 via OTEL_EXPORTER_OTLP_ENDPOINT.
# When running inside the demo docker-compose, the collector is reachable as otel-collector:4317.
# For local development you can use http://localhost:4317.
export OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Protocol for OTLP export (http/protobuf recommended)
export OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Service name (overridden per experiment, but good to have a default)
export OTEL_SERVICE_NAME=postgres-chaos-test

# Service namespace for grouping experiments
export OTEL_SERVICE_NAMESPACE=chaos-engineering

# =============================================================================
# PostgreSQL Connection Configuration
# =============================================================================

# Primary PostgreSQL host
# For Docker: postgres-primary
# For local development: localhost
export POSTGRES_HOST=postgres-primary

# PostgreSQL port
export POSTGRES_PORT=5432

# Database name
export POSTGRES_DB=testdb

# Database user
export POSTGRES_USER=postgres

# Database password
export POSTGRES_PASSWORD=postgres

# =============================================================================
# Replica Configuration (if using replication tests)
# =============================================================================

export POSTGRES_REPLICA_HOST=postgres-replica
export POSTGRES_REPLICA_PORT=5432

# =============================================================================
# Test Parameters (optional overrides)
# =============================================================================

# Pool Exhaustion Test
# export POOL_NUM_CONNECTIONS=100
# export POOL_DURATION_SECONDS=60

# Query Saturation Test
# export QUERY_NUM_THREADS=20
# export QUERY_QUERIES_PER_THREAD=1000
# export QUERY_DURATION_SECONDS=60

# Lock Storm Test
# export LOCK_NUM_THREADS=10
# export LOCK_DURATION_SECONDS=60

# Slow Transactions Test
# export SLOW_TX_NUM_THREADS=5
# export SLOW_TX_DURATION_SECONDS=60
# export SLOW_TX_DELAY_MS=5000

# =============================================================================
# Usage Examples
# =============================================================================
#
# 1. Source this file:
#    source env.example
#
# 2. Run a specific test:
#    chaos run test-postgres-pool-exhaustion.json
#    chaos run test-postgres-query-saturation.json
#    chaos run test-postgres-lock-storm.json
#    chaos run test-postgres-slow-transactions.json
#
# 3. Run all postgres tests:
#    for f in test-postgres-*.json; do chaos run "$f"; done
#
# 4. Override a specific variable:
#    POSTGRES_HOST=my-postgres-host chaos run test-postgres-pool-exhaustion.json
#

