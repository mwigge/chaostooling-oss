{
  "version": "1.0.0",
  "title": "ActiveMQ Chaos Engineering Experiment",
  "description": "Focused chaos engineering experiment for ActiveMQ messaging system. Tests ActiveMQ resilience under message flood scenarios with continuous transaction load. All scenarios run with background transaction load targeting ActiveMQ.",
  "tags": [
    "activemq",
    "messaging",
    "chaos",
    "resilience",
    "observability",
    "production"
  ],
  "configuration": {
    "_comment": "=== PRIMARY SITE (Site A) ===",
    "site_a_haproxy_url": {
      "type": "env",
      "key": "SITE_A_HAPROXY_URL",
      "default": "http://haproxy-site-a:80"
    },
    "_comment2": "=== ACTIVEMQ CONFIGURATION ===",
    "activemq_host": {
      "type": "env",
      "key": "ACTIVEMQ_HOST",
      "default": "activemq"
    },
    "activemq_port": {
      "type": "env",
      "key": "ACTIVEMQ_PORT",
      "default": "61616"
    },
    "activemq_web_port": {
      "type": "env",
      "key": "ACTIVEMQ_WEB_PORT",
      "default": "8161"
    },
    "_comment3": "=== CHAOS PARAMETERS ===",
    "stress_duration": {
      "type": "env",
      "key": "STRESS_DURATION",
      "default": "300"
    },
    "num_threads": {
      "type": "env",
      "key": "NUM_THREADS",
      "default": "10"
    },
    "_comment4": "=== TEST PARAMETERS ===",
    "baseline_transactions": {
      "type": "env",
      "key": "TEST_BASELINE_TRANSACTIONS",
      "default": "50"
    },
    "distributed_transaction_test_count": {
      "type": "env",
      "key": "TEST_DISTRIBUTED_TXN_COUNT",
      "default": "30"
    },
    "_comment5": "=== OBSERVABILITY ===",
    "otel_service_name": {
      "type": "env",
      "key": "OTEL_SERVICE_NAME",
      "default": "activemq-chaos-experiment"
    },
    "_comment6": "=== BACKGROUND TRANSACTION LOAD ===",
    "load_generator_url": {
      "type": "env",
      "key": "TRANSACTION_LOAD_GENERATOR_URL",
      "default": "http://transaction-load-generator:5001"
    },
    "load_generator_tps": {
      "type": "env",
      "key": "TRANSACTION_LOAD_GENERATOR_TPS",
      "default": "2.0"
    },
    "auto_start_load_generator": {
      "type": "env",
      "key": "AUTO_START_LOAD_GENERATOR",
      "default": "true"
    },
    "reporting_output_dir": {
      "type": "env",
      "key": "CHAOS_REPORTING_OUTPUT_DIR",
      "default": "/var/log/chaostoolkit/reports"
    },
    "reporting_formats": {
      "type": "env",
      "key": "CHAOS_REPORTING_FORMATS",
      "default": "html,json"
    }
  },
  "controls": [
    {
      "name": "env-loader",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.env_loader_control"
      }
    },
    {
      "name": "opentelemetry",
      "provider": {
        "type": "python",
        "module": "chaosotel.control"
      }
    },
    {
      "name": "reporting",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.control"
      }
    },
    {
      "name": "load_generator",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.load_generator_control"
      }
    }
  ],
  "steady-state-hypothesis": {
    "title": "ActiveMQ system is healthy and accessible",
    "probes": [
      {
        "name": "probe-site-a-haproxy",
        "type": "probe",
        "provider": {
          "type": "http",
          "url": "${site_a_haproxy_url}/haproxy?stats",
          "method": "GET",
          "timeout": 5
        },
        "tolerance": 200
      },
      {
        "name": "probe-activemq",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.activemq.activemq_connectivity",
          "func": "probe_activemq_connectivity",
          "arguments": {
            "host": "${activemq_host}",
            "port": "${activemq_port}"
          }
        },
        "tolerance": true
      },
      {
        "name": "probe-purchase-requests",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.postgres.postgres_transaction_validation",
          "func": "probe_api_transaction_flow",
          "arguments": {
            "api_url": "${site_a_haproxy_url}",
            "num_transactions": 5
          }
        },
        "tolerance": {
          "type": "jsonpath",
          "path": "$.success",
          "expect": true
        }
      }
    ]
  },
  "method": [
    {
      "_comment_phase": "=== PHASE 1: BASELINE - Establish baseline with load generator starting ===",
      "name": "baseline-activemq-transaction-flow",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_transaction_validation",
        "func": "probe_api_transaction_flow",
        "arguments": {
          "api_url": "${site_a_haproxy_url}",
          "num_transactions": "${baseline_transactions}"
        }
      }
    },
    {
      "name": "verify-baseline-activemq-connectivity",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.activemq.activemq_connectivity",
        "func": "probe_activemq_connectivity",
        "arguments": {
          "host": "${activemq_host}",
          "port": "${activemq_port}"
        }
      },
      "tolerance": true
    },
    {
      "_comment_phase": "=== PHASE 2: ACTIVEMQ CHAOS SCENARIOS (During transaction load) ===",
      "name": "SCENARIO-22-ActiveMQ-Message-Flood",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.activemq.activemq_message_flood",
        "func": "inject_message_flood",
        "arguments": {
          "host": "${activemq_host}",
          "port": "${activemq_port}",
          "user": "admin",
          "password": "admin",
          "queue": "chaos.test",
          "num_producers": 10,
          "messages_per_producer": 1000,
          "duration_seconds": "${stress_duration}"
        }
      }
    },
    {
      "name": "test-transactions-during-activemq-message-flood",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_transaction_validation",
        "func": "probe_api_transaction_flow",
        "arguments": {
          "api_url": "${site_a_haproxy_url}",
          "num_transactions": "${distributed_transaction_test_count}"
        }
      }
    },
    {
      "name": "probe-activemq-message-flood-status",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.activemq.activemq_message_flood_status",
        "func": "probe_message_flood_status",
        "arguments": {
          "host": "${activemq_host}",
          "port": "${activemq_port}",
          "queue": "chaos.test"
        }
      },
      "tolerance": true
    },
    {
      "_comment_phase": "=== PHASE 3: FINAL VALIDATION ===",
      "name": "verify-activemq-connectivity-after-operations",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.activemq.activemq_connectivity",
        "func": "probe_activemq_connectivity",
        "arguments": {
          "host": "${activemq_host}",
          "port": "${activemq_port}"
        }
      },
      "tolerance": true
    }
  ],
  "rollbacks": [
    {
      "type": "action",
      "name": "generate-experiment-reports",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.actions",
        "func": "generate_experiment_reports",
        "arguments": {
          "output_dir": "${reporting_output_dir}",
          "formats": "${reporting_formats}",
          "executive": true,
          "compliance": true,
          "audit": true,
          "product_owner": true
        }
      }
    }
  ]
}

