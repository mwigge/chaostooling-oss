# ============================================
# E2E Test Scenario
# Environment Variables Configuration
# ============================================
# This file contains all environment variables used by the experiment.
# Place this file in the same directory as the experiment JSON file.
# The env-loader control will automatically load these variables.

# ============================================
# OBSERVABILITY
# ============================================
OTEL_SERVICE_NAME=chaostoolkit-e2e-test

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_DB=testdb
POSTGRES_HOST=postgres-primary
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_PRIMARY_HOST=postgres-primary
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_USER=postgres

# ============================================
# CHAOS PARAMETERS
# ============================================
CHAOS_CPU_CORES=2
CHAOS_CPU_DURATION_S=30
CHAOS_CPU_LOAD=80
CHAOS_DB_POOL_CONNECTIONS=50
CHAOS_DB_POOL_DURATION_S=20
CHAOS_DB_SATURATION_DURATION_S=30
CHAOS_DB_SATURATION_THREADS=10
CHAOS_DB_SLOW_TXN_DELAY_MS=3000
CHAOS_DB_SLOW_TXN_DURATION_S=20
CHAOS_DB_SLOW_TXN_THREADS=5
CHAOS_DNS_TIMEOUT_S=20
CHAOS_MEMORY_AMOUNT=500M
CHAOS_MEMORY_DURATION_S=30
CHAOS_NETWORK_DURATION_S=30
CHAOS_NETWORK_JITTER_MS=50
CHAOS_NETWORK_LATENCY_MS=500

# ============================================
# TEST PARAMETERS
# ============================================
TEST_BASELINE_TRANSACTIONS=20
TEST_FAILOVER_TRANSACTIONS=10
TEST_LATENCY_TRANSACTIONS=5
TEST_PERFORMANCE_TRANSACTIONS=50
TEST_RECOVERY_WAIT_S=10
TEST_REPLICATION_CATCHUP_WAIT_S=15
TEST_REPLICATION_TRANSACTIONS=15

# ============================================
# OTHER
# ============================================
APP_SERVER_1_URL=http://app-server-1:5000
APP_SERVER_2_URL=http://app-server-2:5000
HAPROXY_URL=http://haproxy:80
PAYMENT_SERVICE_URL=http://payment-service:5000

