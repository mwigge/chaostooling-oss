{
  "version": "1.0.0",
  "title": "Redis Chaos Engineering Experiment",
  "description": "Focused chaos engineering experiment for Redis database system. Tests Redis resilience under various failure scenarios with continuous transaction load. Includes scenarios: Key Contention and Command Saturation. All scenarios run with background transaction load targeting Redis.",
  "tags": [
    "redis",
    "database",
    "chaos",
    "resilience",
    "observability",
    "production"
  ],
  "configuration": {
    "_comment": "=== PRIMARY SITE (Site A) ===",
    "site_a_haproxy_url": {
      "type": "env",
      "key": "SITE_A_HAPROXY_URL",
      "default": "http://haproxy-site-a:80"
    },
    "_comment2": "=== REDIS CONFIGURATION ===",
    "redis_host": {
      "type": "env",
      "key": "REDIS_HOST",
      "default": "redis"
    },
    "redis_port": {
      "type": "env",
      "key": "REDIS_PORT",
      "default": "6379"
    },
    "_comment3": "=== CHAOS PARAMETERS ===",
    "stress_duration": {
      "type": "env",
      "key": "STRESS_DURATION",
      "default": "300"
    },
    "num_threads": {
      "type": "env",
      "key": "NUM_THREADS",
      "default": "10"
    },
    "_comment4": "=== TEST PARAMETERS ===",
    "baseline_transactions": {
      "type": "env",
      "key": "TEST_BASELINE_TRANSACTIONS",
      "default": "50"
    },
    "distributed_transaction_test_count": {
      "type": "env",
      "key": "TEST_DISTRIBUTED_TXN_COUNT",
      "default": "30"
    },
    "_comment5": "=== OBSERVABILITY ===",
    "otel_service_name": {
      "type": "env",
      "key": "OTEL_SERVICE_NAME",
      "default": "redis-chaos-experiment"
    },
    "_comment6": "=== BACKGROUND TRANSACTION LOAD ===",
    "load_generator_url": {
      "type": "env",
      "key": "TRANSACTION_LOAD_GENERATOR_URL",
      "default": "http://transaction-load-generator:5001"
    },
    "load_generator_tps": {
      "type": "env",
      "key": "TRANSACTION_LOAD_GENERATOR_TPS",
      "default": "2.0"
    },
    "auto_start_load_generator": {
      "type": "env",
      "key": "AUTO_START_LOAD_GENERATOR",
      "default": "true"
    },
    "reporting_output_dir": {
      "type": "env",
      "key": "CHAOS_REPORTING_OUTPUT_DIR",
      "default": "/var/log/chaostoolkit/reports"
    },
    "reporting_formats": {
      "type": "env",
      "key": "CHAOS_REPORTING_FORMATS",
      "default": "html,json"
    }
  },
  "controls": [
    {
      "name": "env-loader",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.env_loader_control"
      }
    },
    {
      "name": "opentelemetry",
      "provider": {
        "type": "python",
        "module": "chaosotel.control"
      }
    },
    {
      "name": "dynamic-steady-state",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.dynamic_steady_state_control"
      }
    },
    {
      "name": "reporting",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.control"
      }
    },
    {
      "name": "load_generator",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.load_generator_control"
      }
    }
  ],
  "dynamic_steady_state": {
    "enabled": true,
    "period": "30d",
    "metrics": [
      "chaos_db_query_count_total{db_system=\"redis\"}",
      "chaos_db_error_count_total{db_system=\"redis\"}",
      "postgresql_commits_total"
    ],
    "sources": [
      "grafana",
      "prometheus",
      "database",
      "file"
    ],
    "threshold_sigma": 2.0
  },
  "steady-state-hypothesis": {
    "title": "Redis system is healthy and accessible",
    "probes": [
      {
        "name": "probe-site-a-haproxy",
        "type": "probe",
        "provider": {
          "type": "http",
          "url": "${site_a_haproxy_url}/haproxy?stats",
          "method": "GET",
          "timeout": 5
        },
        "tolerance": 200
      },
      {
        "name": "probe-redis",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.redis.redis_connectivity",
          "func": "probe_redis_connectivity",
          "arguments": {
            "host": "${redis_host}",
            "port": "${redis_port}"
          }
        },
        "tolerance": true
      },
      {
        "name": "probe-purchase-requests",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.postgres.postgres_transaction_validation",
          "func": "probe_api_transaction_flow",
          "arguments": {
            "api_url": "${site_a_haproxy_url}",
            "num_transactions": 5
          }
        },
        "tolerance": {
          "type": "jsonpath",
          "path": "$.success",
          "expect": true
        }
      }
    ]
  },
  "method": [
    {
      "_comment_phase": "=== PHASE 1: BASELINE - Establish baseline with load generator starting ===",
      "name": "baseline-redis-transaction-flow",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_transaction_validation",
        "func": "probe_api_transaction_flow",
        "arguments": {
          "api_url": "${site_a_haproxy_url}",
          "num_transactions": "${baseline_transactions}"
        }
      }
    },
    {
      "name": "verify-baseline-redis-connectivity",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.redis.redis_connectivity",
        "func": "probe_redis_connectivity",
        "arguments": {
          "host": "${redis_host}",
          "port": "${redis_port}"
        }
      },
      "tolerance": true
    },
    {
      "_comment_phase": "=== PHASE 2: REDIS CHAOS SCENARIOS (During transaction load) ===",
      "name": "SCENARIO-14-Redis-Key-Contention",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.redis.redis_key_contention",
        "func": "inject_key_contention",
        "arguments": {
          "host": "${redis_host}",
          "port": "${redis_port}",
          "num_threads": 10,
          "duration_seconds": "${stress_duration}"
        }
      }
    },
    {
      "name": "test-transactions-during-redis-contention",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_transaction_validation",
        "func": "probe_api_transaction_flow",
        "arguments": {
          "api_url": "${site_a_haproxy_url}",
          "num_transactions": "${distributed_transaction_test_count}"
        }
      }
    },
    {
      "name": "probe-redis-key-contention-status",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.redis.redis_key_contention_status",
        "func": "probe_key_contention_status",
        "arguments": {
          "host": "${redis_host}",
          "port": "${redis_port}"
        }
      },
      "tolerance": true
    },
    {
      "name": "SCENARIO-15-Redis-Command-Saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.redis.redis_command_saturation",
        "func": "inject_command_saturation",
        "arguments": {
          "host": "${redis_host}",
          "port": "${redis_port}",
          "num_threads": 20,
          "duration_seconds": "${stress_duration}"
        }
      }
    },
    {
      "name": "test-transactions-during-redis-command-saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_transaction_validation",
        "func": "probe_api_transaction_flow",
        "arguments": {
          "api_url": "${site_a_haproxy_url}",
          "num_transactions": "${distributed_transaction_test_count}"
        }
      }
    },
    {
      "name": "probe-redis-command-saturation-status",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.redis.redis_command_saturation_status",
        "func": "probe_command_saturation_status",
        "arguments": {
          "host": "${redis_host}",
          "port": "${redis_port}"
        }
      },
      "tolerance": true
    },
    {
      "_comment_phase": "=== PHASE 3: FINAL VALIDATION ===",
      "name": "verify-redis-connectivity-after-operations",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.redis.redis_connectivity",
        "func": "probe_redis_connectivity",
        "arguments": {
          "host": "${redis_host}",
          "port": "${redis_port}"
        }
      },
      "tolerance": true
    }
  ],
  "rollbacks": [
    {
      "type": "action",
      "name": "generate-experiment-reports",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.actions",
        "func": "generate_experiment_reports",
        "arguments": {
          "output_dir": "${reporting_output_dir}",
          "formats": "${reporting_formats}",
          "executive": true,
          "compliance": true,
          "audit": true,
          "product_owner": true
        }
      }
    }
  ]
}