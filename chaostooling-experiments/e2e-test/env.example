#!/bin/bash
# E2E Test Scenario - Environment Configuration
# Copy this file and customize for your environment:
#   cp env.example env.local
#   source env.local
#   chaos run e2e-test-scenario.json
#
# =============================================================================
# IMPORTANT: Values that CANNOT be configured via environment variables
# =============================================================================
# Chaos Toolkit does NOT support variable substitution in tolerance "range" arrays.
# The following values are hardcoded in e2e-test-scenario.json and must be edited
# directly in the JSON file if you need to change them:
#
#   - Steady-state CPU tolerance:      range [0, 100]
#   - Steady-state Memory tolerance:   range [0, 100]  
#   - Steady-state Uptime tolerance:   range [0, 1000000000]
#
# To modify these, edit the "tolerance" blocks in the "steady-state-hypothesis"
# section of e2e-test-scenario.json
# =============================================================================

# =============================================================================
# INFRASTRUCTURE HOSTS
# =============================================================================
export POSTGRES_PRIMARY_HOST=postgres-primary
export POSTGRES_REPLICA_HOST=postgres-replica
export POSTGRES_PORT=5432
export HAPROXY_URL=http://haproxy:80
export APP_SERVER_1_URL=http://app-server-1:5000
export APP_SERVER_2_URL=http://app-server-2:5000
export PAYMENT_SERVICE_URL=http://payment-service:5000

# Database connection (used by extensions)
export POSTGRES_HOST=postgres-primary
export POSTGRES_DB=testdb
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=changeme

# =============================================================================
# CHAOS ACTION PARAMETERS - Network
# =============================================================================
# Network latency to inject (milliseconds)
export CHAOS_NETWORK_LATENCY_MS=500

# Network jitter to inject (milliseconds)
export CHAOS_NETWORK_JITTER_MS=50

# Duration of network chaos (seconds)
export CHAOS_NETWORK_DURATION_S=30

# Duration of DNS timeout simulation (seconds)
export CHAOS_DNS_TIMEOUT_S=20

# Network interface for tc commands
export CHAOS_NETWORK_INTERFACE=eth0

# DNS port for iptables rules
export CHAOS_DNS_PORT=53

# =============================================================================
# CHAOS ACTION PARAMETERS - Compute
# =============================================================================
# CPU stress duration (seconds)
export CHAOS_CPU_DURATION_S=30

# CPU stress load percentage (0-100)
export CHAOS_CPU_LOAD=80

# Number of CPU cores to stress (0 = all available)
export CHAOS_CPU_CORES=2

# Memory stress duration (seconds)
export CHAOS_MEMORY_DURATION_S=30

# Memory stress amount (e.g., 500M, 1G)
export CHAOS_MEMORY_AMOUNT=500M

# =============================================================================
# CHAOS ACTION PARAMETERS - Database
# =============================================================================
# Slow transaction threads
export CHAOS_DB_SLOW_TXN_THREADS=5

# Slow transaction duration (seconds)
export CHAOS_DB_SLOW_TXN_DURATION_S=20

# Slow transaction delay (milliseconds)
export CHAOS_DB_SLOW_TXN_DELAY_MS=3000

# Connection pool exhaustion - number of connections
export CHAOS_DB_POOL_CONNECTIONS=50

# Connection pool exhaustion duration (seconds)
export CHAOS_DB_POOL_DURATION_S=20

# Query saturation threads
export CHAOS_DB_SATURATION_THREADS=10

# Query saturation duration (seconds)
export CHAOS_DB_SATURATION_DURATION_S=30

# =============================================================================
# TEST PARAMETERS
# =============================================================================
# Baseline transaction count for initial testing
export TEST_BASELINE_TRANSACTIONS=20

# Transaction count for failover tests
export TEST_FAILOVER_TRANSACTIONS=10

# Transaction count for latency tests
export TEST_LATENCY_TRANSACTIONS=5

# Transaction count for replication tests
export TEST_REPLICATION_TRANSACTIONS=15

# Transaction count for performance tests
export TEST_PERFORMANCE_TRANSACTIONS=50

# Wait time for system recovery (seconds)
export TEST_RECOVERY_WAIT_S=10

# Wait time for replication catchup (seconds)
export TEST_REPLICATION_CATCHUP_WAIT_S=15

# =============================================================================
# OBSERVABILITY
# =============================================================================
export OTEL_SERVICE_NAME=chaostoolkit-e2e-test
export OTEL_SERVICE_NAMESPACE=chaos-engineering
export OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
export OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Optional: force clean OpenTelemetry re-initialization on every ensure_initialized() call.
# Recommended for container-based experiments to ensure metrics export after rebuilds/restarts.
# export CHAOSOTEL_FORCE_REINIT=1

# =============================================================================
# KAFKA (if used)
# =============================================================================
export KAFKA_BOOTSTRAP_SERVERS=kafka:9092
export KAFKA_TOPIC_ORDERS=mobile_orders

