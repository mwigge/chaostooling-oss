    },
    "cpu_stress_load": {
      "type": "env",
      "key": "CHAOS_CPU_LOAD",
      "default": "80"
    },
    "cpu_stress_duration_s": {
      "type": "env",
      "key": "CHAOS_CPU_DURATION_S",
      "default": "30"
    },
    "db_slow_txn_delay_ms": {
      "type": "env",
      "key": "CHAOS_DB_SLOW_TXN_DELAY_MS",
      "default": "3000"
    },
    "db_slow_txn_duration_s": {
      "type": "env",
      "key": "CHAOS_DB_SLOW_TXN_DURATION_S",
      "default": "20"
    },
    "_comment6": "=== TEST PARAMETERS ===",
    "baseline_transactions": {
      "type": "env",
      "key": "TEST_BASELINE_TRANSACTIONS",
      "default": "50"
    },
    "distributed_transaction_test_count": {
      "type": "env",
      "key": "TEST_DISTRIBUTED_TXN_COUNT",
      "default": "30"
    },
    "dr_failover_test_count": {
      "type": "env",
      "key": "TEST_DR_FAILOVER_COUNT",
      "default": "20"
    },
    "_comment7": "=== OBSERVABILITY ===",
    "otel_service_name": {
      "type": "env",
      "key": "OTEL_SERVICE_NAME",
      "default": "production-scale-chaos-experiment"
    },
    "_comment8": "=== BACKGROUND TRANSACTION LOAD ===",
    "load_generator_url": {
      "type": "env",
      "key": "TRANSACTION_LOAD_GENERATOR_URL",
      "default": "http://transaction-load-generator:5001"
    },
    "_comment_load_generator_port": "Note: Container uses port 5001 internally, but host port is 6002 to avoid conflict with app-servers/payment-services (5001-5008)",
    "type": "env",
    "key": "POSTGRES_PASSWORD",
    "default": "postgres"
  },
