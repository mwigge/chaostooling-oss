    },
    "rabbitmq_port": {
      "type": "env",
      "key": "RABBITMQ_PORT",
      "default": "5672"
    },
    "rabbitmq_user": {
      "type": "env",
      "key": "RABBITMQ_USER",
      "default": "chaos"
    },
    "rabbitmq_password": {
      "type": "env",
      "key": "RABBITMQ_PASSWORD",
      "default": "password"
    },
    "activemq_host": {
      "type": "env",
      "key": "ACTIVEMQ_HOST",
      "default": "activemq"
    },
    "activemq_port": {
      "type": "env",
      "key": "ACTIVEMQ_PORT",
      "default": "61616"
    },
    "activemq_web_port": {
      "type": "env",
      "key": "ACTIVEMQ_WEB_PORT",
      "default": "8161"
    },
    "_comment5": "=== CHAOS PARAMETERS ===",
    "network_latency_ms": {
