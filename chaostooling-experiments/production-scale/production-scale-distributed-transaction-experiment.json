      "key": "POSTGRES_DR_HOST",
      "default": "postgres-primary-site-b"
    },
    "postgres_port": {
      "type": "env",
      "key": "POSTGRES_PORT",
      "default": "5432"
    },
    "postgres_db": {
      "type": "env",
      "key": "POSTGRES_DB",
      "default": "testdb"
    },
    "postgres_user": {
      "type": "env",
      "key": "POSTGRES_USER",
      "default": "postgres"
    },
    "postgres_password": {
      "type": "env",
      "key": "POSTGRES_PASSWORD",
      "default": "postgres"
    },
    "mongodb_uri": {
      "type": "env",
      "key": "MONGODB_URI",
      "default": "mongodb://mongodb:27017"
    },
    "mongodb_db": {
      "type": "env",
      "key": "MONGODB_DB",
      "default": "test"
    },
    "redis_host": {
      "type": "env",
      "key": "REDIS_HOST",
      "default": "redis"
    },
    "redis_port": {
      "type": "env",
      "key": "REDIS_PORT",
      "default": "6379"
    },
    "mysql_host": {
      "type": "env",
      "key": "MYSQL_HOST",
      "default": "mysql"
    },
    "mysql_port": {
      "type": "env",
      "key": "MYSQL_PORT",
      "default": "3306"
    },
    "mysql_db": {
      "type": "env",
      "key": "MYSQL_DB",
      "default": "testdb"
    },
    "mysql_user": {
      "type": "env",
      "key": "MYSQL_USER",
      "default": "root"
    },
    "mysql_password": {
      "type": "env",
      "key": "MYSQL_PASSWORD",
      "default": "mysql"
    },
    "mssql_host": {
      "type": "env",
      "key": "MSSQL_HOST",
      "default": "mssql"
    },
    "mssql_port": {
      "type": "env",
      "key": "MSSQL_PORT",
      "default": "1433"
    },
    "mssql_db": {
      "type": "env",
      "key": "MSSQL_DB",
      "default": "master"
