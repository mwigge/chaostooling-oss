"steady-state-hypothesis": {
  "title": "All systems are healthy and accessible across primary and DR sites",
  "probes": [
    {
      "name": "probe-site-a-haproxy",
      "type": "probe",
      "provider": {
        "type": "http",
        "url": "${site_a_haproxy_url}/haproxy?stats",
        "method": "GET",
        "timeout": 5
      },
      "tolerance": 200
    },
    {
      "name": "probe-site-b-haproxy",
      "type": "probe",
      "provider": {
        "type": "http",
        "url": "${site_b_haproxy_url}/haproxy?stats",
        "method": "GET",
        "timeout": 5
      },
      "tolerance": 200
    },
    {
      "name": "probe-site-a-app-servers",
      "type": "probe",
      "provider": {
        "type": "http",
        "url": "${site_a_app_server_1_url}/health",
        "method": "GET",
        "timeout": 5
      },
      "tolerance": 200
    },
    {
      "name": "probe-site-b-app-server",
      "type": "probe",
      "provider": {
        "type": "http",
        "url": "${site_b_app_server_url}/health",
        "method": "GET",
        "timeout": 5
      },
      "tolerance": 200
    },
    {
      "name": "probe-postgres-primary",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_connectivity",
        "func": "probe_postgres_connectivity",
        "arguments": {
          "host": "${postgres_primary_host}",
          "port": "${postgres_port}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-postgres-replica",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_connectivity",
        "func": "probe_postgres_connectivity",
        "arguments": {
          "host": "${postgres_replica_host}",
          "port": "${postgres_port}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-postgres-dr",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_connectivity",
        "func": "probe_postgres_connectivity",
        "arguments": {
          "host": "${postgres_dr_host}",
          "port": "${postgres_port}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-kafka",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.kafka.kafka_connectivity",
        "func": "probe_kafka_connectivity",
        "arguments": {
          "bootstrap_servers": "${kafka_bootstrap_servers}",
          "topic": "${kafka_topic}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-purchase-requests",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.postgres.postgres_transaction_validation",
        "func": "probe_api_transaction_flow",
        "arguments": {
          "api_url": "${site_a_haproxy_url}",
          "num_transactions": 5
        }
      },
      "tolerance": {
        "type": "jsonpath",
        "path": "$.success",
        "expect": true
      }
    },
    {
      "name": "probe-rabbitmq",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.rabbitmq.rabbitmq_connectivity",
        "func": "probe_rabbitmq_connectivity"
      },
      "tolerance": true
    },
    {
      "name": "probe-mongodb",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.mongodb.mongodb_connectivity",
        "func": "probe_mongodb_connectivity",
        "arguments": {
          "host": "mongodb",
          "port": 27017,
          "database": "${mongodb_db}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-redis",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.redis.redis_connectivity",
        "func": "probe_redis_connectivity",
        "arguments": {
          "host": "${redis_host}",
          "port": "${redis_port}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-mysql",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.mysql.mysql_connectivity",
        "func": "probe_mysql_connectivity",
        "arguments": {
          "host": "${mysql_host}",
          "port": "${mysql_port}",
          "database": "${mysql_db}",
          "user": "${mysql_user}",
          "password": "${mysql_password}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-mssql",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.mssql.mssql_connectivity",
        "func": "probe_mssql_connectivity",
        "arguments": {
          "host": "${mssql_host}",
          "port": "${mssql_port}",
          "database": "${mssql_db}",
          "user": "${mssql_user}",
          "password": "${mssql_password}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-cassandra",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.cassandra.cassandra_connectivity",
        "func": "probe_cassandra_connectivity",
        "arguments": {
          "host": "${cassandra_host}",
          "port": "${cassandra_port}",
          "keyspace": "${cassandra_keyspace}"
        }
      },
      "tolerance": true
    },
    {
      "name": "probe-activemq",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosdb.probes.activemq.activemq_connectivity",
        "func": "probe_activemq_connectivity",
        "arguments": {
          "host": "${activemq_host}",
          "port": "${activemq_port}"
        }
      },
      "tolerance": true
    }
  ]
},
"method": [
  {
    "name": "baseline-distributed-transaction-flow",
    "type": "action",
    "provider": {
      "type": "python",
      "module": "chaosdb.probes.postgres.postgres_transaction_validation",
      "func": "probe_api_transaction_flow",
      "arguments": {
        "api_url": "${site_a_haproxy_url}",
        "num_transactions": "${baseline_transactions}"
      }
    }
  },
  {
    "name": "verify-baseline-transactions",
    "type": "probe",
    "provider": {
      "type": "python",
      "module": "chaosdb.probes.postgres.postgres_transaction_validation",
      "func": "probe_transaction_count",
      "arguments": {
        "host": "${postgres_primary_host}",
        "port": "${postgres_port}"
      }
    },
    "tolerance": {
      "type": "jsonpath",
      "path": "$.total_count",
      "expect": 50
    }
  },
  {
    "name": "SCENARIO-1-Network-Latency-Across-Sites",
    "type": "action",
    "provider": {
      "type": "python",
      "module": "chaosnetwork.actions.network_latency",
      "func": "simulate_network_conditions",
      "arguments": {
        "latency": "${network_latency_ms}",
        "duration": "${network_duration_s}"
      }
    }
  },
  {
    "name": "test-distributed-transactions-under-latency",
    "type": "action",
    "provider": {
