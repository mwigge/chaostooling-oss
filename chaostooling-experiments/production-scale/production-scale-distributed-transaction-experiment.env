# ============================================
# Production-Scale Distributed Transaction Chaos Experiment
# Environment Variables Configuration
# ============================================
# This file contains all environment variables used by the experiment.
# Place this file in the same directory as the experiment JSON file.
# The env-loader control will automatically load these variables.

# ============================================
# OBSERVABILITY
# ============================================
OTEL_SERVICE_NAME=production-scale-chaos-experiment

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_DB=testdb
POSTGRES_DR_HOST=postgres-primary-site-b
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
POSTGRES_PRIMARY_HOST=postgres-primary-site-a
POSTGRES_REPLICA_HOST=postgres-replica-site-a
POSTGRES_USER=postgres

# ============================================
# MYSQL
# ============================================
MYSQL_DB=testdb
MYSQL_HOST=mysql
MYSQL_PASSWORD=changeme
MYSQL_PORT=3306
MYSQL_USER=root

# ============================================
# MONGODB
# ============================================
MONGODB_DB=test
MONGODB_URI=mongodb://mongodb:27017

# ============================================
# REDIS
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# MSSQL
# ============================================
MSSQL_DB=master
MSSQL_HOST=mssql
MSSQL_PORT=1433
MSSQL_SA_PASSWORD=changeme
MSSQL_USER=sa

# ============================================
# CASSANDRA
# ============================================
CASSANDRA_HOST=cassandra
CASSANDRA_KEYSPACE=system
CASSANDRA_PORT=9042

# ============================================
# KAFKA
# ============================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=test

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PASSWORD=changeme
RABBITMQ_PORT=5672
RABBITMQ_USER=chaos

# ============================================
# ACTIVEMQ
# ============================================
ACTIVEMQ_HOST=activemq
ACTIVEMQ_PORT=61616
ACTIVEMQ_WEB_PORT=8161

# ============================================
# CHAOS PARAMETERS
# ============================================
CHAOS_CPU_DURATION_S=30
CHAOS_CPU_LOAD=80
CHAOS_DB_SLOW_TXN_DELAY_MS=3000
CHAOS_DB_SLOW_TXN_DURATION_S=20
CHAOS_NETWORK_DURATION_S=30
CHAOS_NETWORK_LATENCY_MS=500

# ============================================
# TEST PARAMETERS
# ============================================
TEST_BASELINE_TRANSACTIONS=50
TEST_DISTRIBUTED_TXN_COUNT=30
TEST_DR_FAILOVER_COUNT=20

# ============================================
# LOAD GENERATOR
# ============================================
AUTO_START_LOAD_GENERATOR=true
TRANSACTION_LOAD_GENERATOR_TPS=2.0
TRANSACTION_LOAD_GENERATOR_URL=http://transaction-load-generator:5001

# ============================================
# SITE A
# ============================================
SITE_A_APP_SERVER_1_URL=http://app-server-1-site-a:5000
SITE_A_APP_SERVER_2_URL=http://app-server-2-site-a:5000
SITE_A_HAPROXY_URL=http://haproxy-site-a:80
SITE_A_INVENTORY_SERVICE_URL=http://inventory-service-site-a:5000
SITE_A_ORDER_SERVICE_URL=http://order-service-site-a:5000
SITE_A_PAYMENT_SERVICE_URL=http://payment-service-site-a:5000

# ============================================
# SITE B
# ============================================
SITE_B_APP_SERVER_URL=http://app-server-site-b:5000
SITE_B_HAPROXY_URL=http://haproxy-site-b:80

