{
  "version": "1.0",
  "title": "Redis Command Saturation Test",
  "description": "Test database resilience under command saturation by flooding Redis with concurrent commands.",
  "configuration": {
    "otelservicename": "redis-command-saturation-test"
  },
  "controls": [
    {
      "name": "opentelemetry",
      "provider": {
        "type": "python",
        "module": "chaosotel.control"
      }
    }
  ],
  "steady-state-hypothesis": {
    "title": "Database is accessible",
    "probes": [
      {
        "name": "probe-redis",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.redis.redis_connectivity",
          "func": "probe_redis_connectivity"
        },
        "tolerance": true
      }
    ]
  },
  "method": [
    {
      "name": "inject-command-saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.redis.redis_command_saturation",
        "func": "inject_command_saturation",
        "arguments": {
          "num_threads": 20,
          "duration_seconds": 60
        }
      }
    }
  ],
  "rollbacks": [
    {
      "name": "stop-command-saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.redis.redis_command_saturation",
        "func": "stop_command_saturation"
      }
    }
  ]
}

