# ============================================
# Extensive PostgreSQL Chaos Experiment
# Environment Variables Configuration
# ============================================
# This file contains all environment variables used by the experiment.
# Place this file in the same directory as the experiment JSON file.
# The env-loader control will automatically load these variables.

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_DB=testdb
POSTGRES_HOST=127.0.0.1
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_REPLICA_HOST=127.0.0.1
POSTGRES_REPLICA_PORT=5433
POSTGRES_USER=postgres

# ============================================
# OTHER
# ============================================
CPU_STRESS_LOAD=80
NETWORK_LATENCY_MS=200
NUM_THREADS=5
ROW_COUNT=1000
STRESS_DURATION=30

