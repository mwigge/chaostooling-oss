{
  "version": "1.0.0",
  "title": "Postgres Temp File Spill Experiment",
  "description": "Force temp file creation via complex sorts",
  "tags": [
    "postgres",
    "temp-files",
    "resource-exhaustion"
  ],
  "configuration": {
    "postgres_host": {
      "type": "env",
      "key": "POSTGRES_HOST",
      "default": "postgres"
    },
    "postgres_port": {
      "type": "env",
      "key": "POSTGRES_PORT",
      "default": "5432"
    },
    "postgres_db": {
      "type": "env",
      "key": "POSTGRES_DB",
      "default": "testdb"
    },
    "postgres_user": {
      "type": "env",
      "key": "POSTGRES_USER",
      "default": "postgres"
    },
    "postgres_password": {
      "type": "env",
      "key": "POSTGRES_PASSWORD",
      "default": "postgres"
    }
  },
  "steady-state-hypothesis": {
    "title": "Temp Files are low",
    "probes": [
      {
        "type": "probe",
        "name": "check-temp-files",
        "tolerance": {
          "type": "range",
          "min": 0,
          "max": 5
        },
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.postgres.postgres_system_metrics",
          "func": "collect_postgres_system_metrics",
          "arguments": {
            "host": "${postgres_host}",
            "port": "${postgres_port}",
            "database": "${postgres_db}",
            "user": "${postgres_user}",
            "password": "${postgres_password}"
          }
        },
        "pauses": {
          "after": 1
        }
      }
    ]
  },
  "method": [
    {
      "type": "action",
      "name": "force-temp-spill",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.postgres.postgres_load",
        "func": "complex_sort_query",
        "arguments": {
          "host": "${postgres_host}",
          "port": "${postgres_port}",
          "database": "${postgres_db}",
          "user": "${postgres_user}",
          "password": "${postgres_password}",
          "table_name": "mobile_purchases",
          "duration_seconds": 30
        }
      },
      "pauses": {
        "after": 5
      }
    }
  ],
  "rollbacks": [],
  "controls": [
    {
      "name": "env-loader",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.env_loader_control"
      }
    },
    {
      "name": "reporting",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.control"
      }
    }
  ]
}