# ============================================
# PostgreSQL Replication Lag Test
# Environment Variables Configuration
# ============================================
# This file contains all environment variables used by the experiment.
# Place this file in the same directory as the experiment JSON file.
# The env-loader control will automatically load these variables.

# ============================================
# OBSERVABILITY
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=postgres-replication-lag-test

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_DB=testdb
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_PRIMARY_HOST=postgres-primary
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_USER=postgres

