{
  "version": "1.0",
  "title": "PostgreSQL Replication Lag Test",
  "description": "Test replication lag monitoring by generating load on primary and measuring lag on replica. Validates that replication lag stays within acceptable bounds under normal and stressed conditions.",
  "configuration": {
    "otelservicename": {
      "type": "env",
      "key": "OTEL_SERVICE_NAME",
      "default": "postgres-replication-lag-test"
    },
    "otelendpoint": {
      "type": "env",
      "key": "OTEL_EXPORTER_OTLP_ENDPOINT",
      "default": "http://otel-collector:4318"
    },
    "postgres_primary_host": {
      "type": "env",
      "key": "POSTGRES_PRIMARY_HOST",
      "default": "postgres-primary"
    },
    "postgres_replica_host": {
      "type": "env",
      "key": "POSTGRES_REPLICA_HOST",
      "default": "postgres-replica"
    },
    "postgres_port": {
      "type": "env",
      "key": "POSTGRES_PORT",
      "default": "5432"
    },
    "postgres_db": {
      "type": "env",
      "key": "POSTGRES_DB",
      "default": "testdb"
    },
    "postgres_user": {
      "type": "env",
      "key": "POSTGRES_USER",
      "default": "postgres"
    },
    "postgres_password": {
      "type": "env",
      "key": "POSTGRES_PASSWORD",
      "default": "postgres"
    },
    "chaos_db_host": {
      "type": "env",
      "key": "CHAOS_DB_HOST",
      "default": "chaos-platform-db"
    },
    "chaos_db_port": {
      "type": "env",
      "key": "CHAOS_DB_PORT",
      "default": "5432"
    }
  },
  "controls": [
    {
      "name": "experiment-orchestrator",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.experiment_orchestrator_control"
      }
    },
    {
      "name": "env-loader",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.env_loader_control"
      }
    },
    {
      "name": "database-storage",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.database_storage_control"
      }
    },
    {
      "name": "database-display",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.database_display_control",
        "arguments": {
          "db_host": "${chaos_db_host}",
          "db_port": "${chaos_db_port}"
        }
      }
    },
    {
      "name": "opentelemetry",
      "provider": {
        "type": "python",
        "module": "chaosotel.control"
      }
    },
    {
      "name": "dynamic-steady-state",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.dynamic_steady_state_control"
      }
    },
    {
      "name": "reporting",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.control"
      }
    },
    {
      "name": "metrics-calculator",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.metrics_calculator_control"
      }
    }
  ],
  "baseline_config": {
    "metadata": {
      "version": "1.0",
      "created": "2026-01-31",
      "service": "postgres",
      "description": "Baseline metrics configuration for postgres replication lag chaos experiment"
    },
    "discovery": {
      "method": "system",
      "system_id": "postgres",
      "service_name": "postgres"
    },
    "default_thresholds": {
      "sigma_threshold": 2.0,
      "critical_sigma": 3.0,
      "enable_anomaly_detection": true,
      "anomaly_method": "zscore"
    },
    "data_validation": {
      "max_age_days": 30,
      "min_quality_score": 75,
      "require_statistical_significance": true
    },
    "metrics": [
      {
        "metric_id": 5001,
        "metric_name": "postgresql_replication_data_delay_bytes",
        "service_name": "postgres",
        "baseline_source": "prometheus",
        "baseline_statistics": {
          "collection_period_days": 30,
          "data_points": 2880,
          "mean_value": 125000.0,
          "stddev_value": 45000.0,
          "min_value": 5000.0,
          "max_value": 450000.0,
          "percentile_50": 110000.0,
          "percentile_95": 210000.0,
          "percentile_99": 380000.0,
          "quality_score": 94
        },
        "threshold_config": {
          "sigma_threshold": 3.0,
          "critical_sigma": 4.0,
          "warning_lower": -10000.0,
          "warning_upper": 260000.0,
          "critical_lower": -55000.0,
          "critical_upper": 305000.0
        },
        "anomaly_detection": {
          "enabled": true,
          "method": "zscore",
          "sensitivity": 0.92
        },
        "status": "active",
        "used_in_probes": ["check-replication-lag"],
        "notes": "Primary data lag in bytes. Critical metric for replication health. High threshold (3.0 sigma) as this is critical."
      },
      {
        "metric_id": 5002,
        "metric_name": "postgresql_replication_slot_lag_bytes",
        "service_name": "postgres",
        "baseline_source": "prometheus",
        "baseline_statistics": {
          "collection_period_days": 30,
          "data_points": 2880,
          "mean_value": 85000.0,
          "stddev_value": 28000.0,
          "min_value": 1000.0,
          "max_value": 320000.0,
          "percentile_50": 75000.0,
          "percentile_95": 145000.0,
          "percentile_99": 280000.0,
          "quality_score": 92
        },
        "threshold_config": {
          "sigma_threshold": 2.5,
          "critical_sigma": 3.5,
          "warning_lower": 15000.0,
          "warning_upper": 155000.0,
          "critical_lower": -13000.0,
          "critical_upper": 183000.0
        },
        "anomaly_detection": {
          "enabled": true,
          "method": "zscore",
          "sensitivity": 0.9
        },
        "status": "active",
        "used_in_probes": ["check-slot-lag"],
        "notes": "Replication slot lag in bytes. Indicates WAL backlog on primary."
      },
      {
        "metric_id": 5003,
        "metric_name": "rate(pg_stat_replication_sync_priority[5m])",
        "service_name": "postgres",
        "baseline_source": "prometheus",
        "baseline_statistics": {
          "collection_period_days": 30,
          "data_points": 2880,
          "mean_value": 1.0,
          "stddev_value": 0.15,
          "min_value": 0.5,
          "max_value": 1.5,
          "percentile_50": 1.0,
          "percentile_95": 1.28,
          "percentile_99": 1.42,
          "quality_score": 90
        },
        "threshold_config": {
          "sigma_threshold": 2.0,
          "critical_sigma": 3.0,
          "warning_lower": 0.7,
          "warning_upper": 1.3,
          "critical_lower": 0.55,
          "critical_upper": 1.45
        },
        "anomaly_detection": {
          "enabled": true,
          "method": "zscore",
          "sensitivity": 0.88
        },
        "status": "active",
        "used_in_probes": ["check-sync-priority"],
        "notes": "Synchronous replication status change rate. Indicates replication stability."
      }
    ]
  },
  "dynamic_steady_state": {
    "enabled": true,
    "period": "30d",
    "metrics": [
      "postgresql_replication_data_delay_bytes",
      "postgresql_commits_total"
    ],
    "sources": ["grafana", "prometheus", "database", "file"],
    "threshold_sigma": 2.0
  },
  "steady-state-hypothesis": {
    "title": "Replication lag is acceptable",
    "probes": [
      {
        "name": "check-replication-lag",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosgeneric.probes.mcp_baseline_probe",
          "func": "check_metric_within_baseline",
          "arguments": {
            "metric_name": "postgresql_replication_data_delay_bytes",
            "service_name": "postgres",
            "baseline_file": "postgres/baseline_metrics.json",
            "threshold_sigma": 2.0,
            "description": "Primary replication lag within acceptable range",
            "db_host": "${chaos_db_host}",
            "db_port": "${chaos_db_port}"
          }
        },
        "tolerance": true
      },
      {
        "name": "replication-lag-baseline",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosgeneric.probes.mcp_baseline_probe",
          "func": "check_metric_within_baseline",
          "arguments": {
            "metric_name": "postgresql_replication_data_delay_bytes",
            "service_name": "postgres",
            "baseline_file": "postgres/baseline_metrics.json",
            "threshold_sigma": 2.0,
            "description": "Replication lag within 2-sigma of baseline",
            "db_host": "${chaos_db_host}",
            "db_port": "${chaos_db_port}"
          }
        },
        "tolerance": true
      }
    ]
  },
  "method": [
    {
      "name": "generate-write-load-on-primary",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.postgres.postgres_load",
        "func": "generate_dead_tuples",
        "arguments": {
          "host": "${postgres_primary_host}",
          "port": "${postgres_port}",
          "database": "${postgres_db}",
          "user": "${postgres_user}",
          "password": "${postgres_password}",
          "table_name": "mobile_purchases",
          "count": 5000
        }
      },
      "pauses": {
        "after": 2
      }
    },
    {
      "name": "verify-replication-lag-after-load",
      "type": "probe",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.probes.mcp_baseline_probe",
        "func": "check_metric_within_baseline",
        "arguments": {
          "metric_name": "postgresql_replication_data_delay_bytes",
          "service_name": "postgres",
          "baseline_file": "postgres/baseline_metrics.json",
          "threshold_sigma": 2.0,
          "description": "Replication lag after load still within acceptable range",
          "db_host": "${chaos_db_host}",
          "db_port": "${chaos_db_port}"
        }
      },
      "tolerance": true
    }
  ],
  "rollbacks": []
}