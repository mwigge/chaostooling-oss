{
  "version": "1.0",
  "title": "PostgreSQL Query Saturation Test",
  "description": "Test database query handling capacity by saturating it with a high volume of concurrent queries to measure performance degradation and identify bottlenecks.",
  "configuration": {
    "otelservicename": {
      "type": "env",
      "key": "OTEL_SERVICE_NAME",
      "default": "postgres-query-saturation-test"
    },
    "otelendpoint": {
      "type": "env",
      "key": "OTEL_EXPORTER_OTLP_ENDPOINT",
      "default": "http://otel-collector:4318"
    },
    "postgres_host": {
      "type": "env",
      "key": "POSTGRES_HOST",
      "default": "postgres-primary"
    },
    "postgres_port": {
      "type": "env",
      "key": "POSTGRES_PORT",
      "default": "5432"
    },
    "postgres_db": {
      "type": "env",
      "key": "POSTGRES_DB",
      "default": "testdb"
    },
    "postgres_user": {
      "type": "env",
      "key": "POSTGRES_USER",
      "default": "postgres"
    },
    "postgres_password": {
      "type": "env",
      "key": "POSTGRES_PASSWORD",
      "default": "postgres"
    }
  },
  "controls": [
    {
      "name": "env-loader",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.env_loader_control"
      }
    },
    {
      "name": "opentelemetry",
      "provider": {
        "type": "python",
        "module": "chaosotel.control"
      }
    },
    {
      "name": "reporting",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.control"
      }
    }
  ],
  "steady-state-hypothesis": {
    "title": "Database is accessible with acceptable query latency and backend load",
    "probes": [
      {
        "name": "connectivity",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.postgres.postgres_connectivity",
          "func": "probe_postgres_connectivity",
          "arguments": {
            "host": "${postgres_host}",
            "port": "${postgres_port}",
            "database": "${postgres_db}",
            "user": "${postgres_user}",
            "password": "${postgres_password}"
          }
        },
        "tolerance": true
      },
      {
        "name": "query-latency",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosgeneric.probes.mcp_baseline_probe",
          "func": "check_metric_within_baseline",
          "arguments": {
            "metric_name": "pg_query_duration_milliseconds",
            "service_name": "postgres",
            "baseline_file": "postgres/baseline_metrics.json",
            "threshold_sigma": 1.5,
            "description": "Query latency p95 within 1.5-sigma of baseline"
          }
        },
        "tolerance": true
      },
      {
        "name": "slow-query-count",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosgeneric.probes.mcp_baseline_probe",
          "func": "check_metric_within_baseline",
          "arguments": {
            "metric_name": "pg_slow_queries_count",
            "service_name": "postgres",
            "baseline_file": "postgres/baseline_metrics.json",
            "threshold_sigma": 2.0,
            "description": "Slow query count (>1s) within 2-sigma of baseline"
          }
        },
        "tolerance": true
      },
      {
        "name": "active-backends",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosgeneric.probes.mcp_baseline_probe",
          "func": "check_metric_within_baseline",
          "arguments": {
            "metric_name": "pg_stat_activity_count",
            "service_name": "postgres",
            "baseline_file": "postgres/baseline_metrics.json",
            "threshold_sigma": 2.0,
            "description": "Active backends within 2-sigma of baseline"
          }
        },
        "tolerance": true
      }
    ]
  },
  "method": [
    {
      "name": "inject-query-saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.postgres.postgres_query_saturation",
        "func": "inject_query_saturation",
        "arguments": {
          "host": "${postgres_host}",
          "port": "${postgres_port}",
          "database": "${postgres_db}",
          "user": "${postgres_user}",
          "password": "${postgres_password}",
          "num_threads": 20,
          "queries_per_thread": 1000,
          "duration_seconds": 60,
          "slow_query_threshold_ms": 1000
        }
      }
    }
  ],
  "rollbacks": [
    {
      "name": "stop-query-saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.postgres.postgres_query_saturation",
        "func": "stop_query_saturation"
      }
    }
  ]
}