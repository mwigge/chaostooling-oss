{
  "version": "1.0",
  "title": "MongoDB Query Saturation Test",
  "description": "Test database resilience under query saturation by flooding the database with concurrent queries.",
  "configuration": {
    "otelservicename": "mongodb-query-saturation-test"
  },
  "controls": [
    {
      "name": "env-loader",
      "provider": {
        "type": "python",
        "module": "chaosgeneric.control.env_loader_control"
      }
    },
    {
      "name": "opentelemetry",
      "provider": {
        "type": "python",
        "module": "chaosotel.control"
      }
    },
    {
      "name": "reporting",
      "provider": {
        "type": "python",
        "module": "chaostooling_reporting.control"
      }
    }
  ],
  "steady-state-hypothesis": {
    "title": "Database is accessible",
    "probes": [
      {
        "name": "probe-mongodb",
        "type": "probe",
        "provider": {
          "type": "python",
          "module": "chaosdb.probes.mongodb.mongodb_connectivity",
          "func": "probe_mongodb_connectivity"
        },
        "tolerance": true
      }
    ]
  },
  "method": [
    {
      "name": "inject-query-saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.mongodb.mongodb_query_saturation",
        "func": "inject_query_saturation",
        "arguments": {
          "num_threads": 20,
          "duration_seconds": 60
        }
      }
    }
  ],
  "rollbacks": [
    {
      "name": "stop-query-saturation",
      "type": "action",
      "provider": {
        "type": "python",
        "module": "chaosdb.actions.mongodb.mongodb_query_saturation",
        "func": "stop_query_saturation"
      }
    }
  ]
}